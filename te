$cs = "Server=10.10.15.86,1433;Database=pn-db-new;Integrated Security=True;Encrypt=True;TrustServerCertificate=True;"
$cn = New-Object System.Data.SqlClient.SqlConnection $cs
$cn.Open()
$cmd = $cn.CreateCommand()
$cmd.CommandText = "SELECT TOP 20 Id, CreateDate, Name FROM [landau].[AccountStatements] WHERE IsDeleted = 0 ORDER BY CreateDate DESC"
$r = $cmd.ExecuteReader()
while ($r.Read()) {
    Write-Host ("{0}  |  {1}" -f $r['CreateDate'], $r['Name'])
}
$r.Close()
$cn.Close()
